      "./domains/carrier/*",
      "./domains/media/*",
      "./domains/government/*",
      "./domains/industrial/*",
      "./domains/platform/*",
      "./domains/finance/*",
      "./domains/x-initiatives/*"
    ],
    "regions": [
      "./regions/eu-political.json",
      "./regions/na.json",
      "./regions/as.json",
      "./regions/af.json"
    ],
    "exclude": {
