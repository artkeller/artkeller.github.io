{
  "id": "resilience-policy",

  "what": {
    "domains": [
      "./domains/infrastructure/*",
      "./domains/media/*",
      "./domains/industrial/*"
    ],
    "regions": [
      "./regions/eu.json",
      "./regions/as.json",
      "./regions/na.json",
      "./regions/af.json",
      "./regions/sa.json"
    ]
  },

  "how": [
    "./analysis-profiles/resilience-analysis.json"
  ],

  "selection": {
    "regex": true,
    "recursive": true,
    "minDomains": 3,
    "minRegions": 5,
    "failureTolerance": 0.3
  }
}
