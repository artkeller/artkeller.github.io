  "profiles": [
    {
      "@id": "urn:iof:profile:standard-analysis",
      "@type": "AnalysisProfile",
      "id": "standard-analysis",
      "ref": "./analysis-profiles/standard-analysis.json",
      "name": "Standard Economic Analysis",
      "version": "1.0",
      "description": "General-purpose availability analysis for economic and industrial internet reachability. Applies balanced weights across infrastructure tiers. Suitable for civilian governance profiles without critical infrastructure mandate.",
      "rational": "Provides a baseline evaluation framework for multi-domain reachability. Latency thresholds reflect typical web service expectations. Colour thresholds follow majority-availability semantics.",
      "standard": "IOF-ANALYSIS-v1",
      "weights": {
        "infrastructure": 5,
        "continent": 4,
        "country": 1
      },
      "latency": {
        "good": 500,
        "acceptable": 1500,
        "critical": 4000
      },
      "thresholds": {
        "BLU": 1,
        "GRN": 0.8,
        "AMB": 0.5,
        "RED": 0
      }
    },
    {
      "@id": "urn:iof:profile:passive-standard",
      "@type": "MeasurementProfile",
      "id": "passive-standard",
      "ref": "./measurement-profiles/passive-standard.json",
      "name": "Passive Standard Measurement",
      "version": "1.0",
      "description": "Conservative passive measurement profile for civilian use. Suitable for all public internet endpoints without special authorization. Respects robots.txt, minimal footprint.",
      "conflictClass": "passive",
      "schedule": {
        "interval": 300,
        "unit": "seconds",
        "timeWindow": "24x7",
        "cooldownAfterError": 60,
        "burstAllowed": false
      },
      "method": {
        "primary": "HEAD",
        "fallback": "GET",
        "followRedirects": 3,
        "tlsValidation": true,
        "tlsMinVersion": "TLS1.2"
      },
      "timeouts": {
        "connect": 5000,
        "response": 8000,
        "total": 10000
      },
      "sources": {
        "type": "single",
        "distributed": false
      },
      "legal": {
        "robotsTxtRespect": true,
        "rateLimit": "conservative",
        "maxRequestsPerMinutePerUrl": 1,
        "userAgent": "IOF-Monitor/1.0 (passive; +https://iof.example/about)",
        "notes": "Passive monitoring only. No stress testing. No authentication bypass."
      },
      "alerting": {
        "onDown": "immediate",
        "onDegraded": "15min",
        "statrep": "1h",
        "colourTransitionAlert": true
      },
      "metrics": {
        "record": [
          "latency_ms",
          "status_code",
          "tls_valid",
          "redirect_count"
        ],
        "percentiles": [
          "p50",
          "p95",
          "p99"
        ],
        "windowSize": "1h",
        "retentionDays": 30
      }
    }
  ],
