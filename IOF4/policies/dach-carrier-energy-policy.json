{
  "id": "dach-carrier-energy-policy",

  "what": {
    "domains": {
      "match": [
        { "field": "domain",    "op": "in",       "value": ["carrier","energy"] },
        { "field": "countries", "op": "intersects","value": "$regions" },
        { "field": "countries", "op": "not-in",   "value": ["*"] }
      ]
    },
    "regions": [
      "./regions/dach.json"
    ]
  },

  "how": ["./analysis-profiles/resilience-analysis.json"],

  "selection": {
    "matchLogic": "AND",
    "includeGlobal": false
  }
}
