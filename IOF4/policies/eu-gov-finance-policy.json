{
  "id": "eu-gov-finance-policy",

  "what": {
    "domains": {
      "match": [
        { "field": "domain",    "op": "in",       "value": ["government","finance"] },
        { "field": "countries", "op": "intersects","value": "$regions" },
        { "field": "countries", "op": "not-in",   "value": ["*"] }
      ]
    },
    "regions": [
      "./regions/eu-political.json"
    ]
  },

  "how": ["./analysis-profiles/standard-analysis.json"],

  "selection": {
    "matchLogic": "AND",
    "includeGlobal": false
  }
}
