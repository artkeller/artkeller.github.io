{
  "id": "resilience-policy",
  "what": {
    "domains": [
      "./domains/infrastructure/*",
      "./domains/carrier/*",
      "./domains/energy/*",
      "./domains/media/*",
      "./domains/industrial/*"
    ],
    "regions": [
      "./regions/eu-all.json",
      "./regions/na.json",
      "./regions/as.json",
      "./regions/af.json",
      "./regions/sa.json"
    ],
    "exclude": {
      "paths": [
        "./domains/test/*"
      ]
    }
  },
  "how": [
    "./analysis-profiles/resilience-analysis.json"
  ],
  "selection": {
    "countryMatch": "intersection",
    "includeGlobal": true,
    "minDomains": 3,
    "minRegions": 5,
    "failureTolerance": 0.3
  },
  "measure": [
    "./measurement-profiles/passive-standard.json"
  ]
}