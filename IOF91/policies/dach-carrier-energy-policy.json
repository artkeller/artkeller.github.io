{
  "id": "dach-carrier-energy-policy",
  "name": "Dach Carrier Energy Policy",
  "version": "1.0",
  "what": {
    "domains": {
      "match": [
        {
          "field": "domain",
          "op": "in",
          "value": [
            "carrier",
            "energy"
          ]
        },
        {
          "field": "countries",
          "op": "intersects",
          "value": "$regions"
        },
        {
          "field": "countries",
          "op": "not-in",
          "value": [
            "*"
          ]
        }
      ]
    },
    "regions": [
      "./regions/dach.json"
    ],
    "exclude": {
      "paths": [
        "./domains/test/*"
      ]
    }
  },
  "how": [
    "./analysis-profiles/resilience-analysis.json",
    "./measurement-profiles/passive-standard.json"
  ],
  "selection": {
    "matchLogic": "AND",
    "includeGlobal": false
  }
}