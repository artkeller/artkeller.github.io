{
  "id": "ai-global-reachability-policy",
  "name": "AI Global Reachability & Governance Policy",
  "version": "1.0",
  "what": {
    "ai_systems": {
      "match": [
        { "field": "category", "op": "in", "value": ["llm", "embedding", "tts", "video"] },
        { "field": "type", "op": "in", "value": ["api", "web", "sdk"] }
      ]
    },
    "jurisdictions": {
      "match": [
        { "field": "legal_framework", "op": "in", "value": ["EU AI Act", "Basic Act on AI", "CCP Guidelines"] }
      ]
    }
  },
  "exclude": {
    "paths": ["./ai-systems/test/*", "./ai-systems/deprecated/*"],
    "match": [
      { "field": "sunset_date", "op": "lt", "value": "2026-01-01" }
    ]
  },
  "how": [
    "./ai-analysis/global-governance-analysis.json",
    "./ai-measurement/entrypoint-measure.json"
  ],
  "selection": {
    "matchLogic": "AND",
    "includeGlobal": true,
    "prioritize_by": "governance_maturity"
  }
}
