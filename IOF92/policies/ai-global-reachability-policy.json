{
  "id": "ai-global-reachability",
  "name": "AI Global Reachability & Governance Policy",
  "version": "1.0",
  "rational": "Measure availability and compliance of AI systems worldwide, considering regional legal frameworks and entry point types.",
  "what": {
    "ai_systems": {
      "match": [
        { "field": "category", "op": "in", "value": ["llm", "embedding", "tts", "stt", "video", "multimodal"] },
        { "field": "access_type", "op": "in", "value": ["api", "web", "sdk", "cli"] }
      ],
      "matchLogic": "AND"
    },
    "jurisdictions": {
      "match": [
        { "field": "legal_framework", "op": "intersects", "value": ["EU AI Act", "Basic Act on AI", "CCP Guidelines", "US EO 14110"] }
      ]
    }
  },
  "exclude": {
    "paths": ["./ai-domains/test/", "./ai-domains/deprecated/"],
    "match": [
      { "field": "sunset_date", "op": "lt", "value": "2026-01-01" }
    ]
  },
  "how": [
    "./analysis-profiles/ai-governance-analysis.json",
    "./measurement-profiles/ai-entrypoint-measure-passive.json",
    "./measurement-profiles/ai-compliance-active.json"
  ],
  "selection": {
    "matchLogic": "AND",
    "includeGlobal": true,
    "prioritize_by": "governance_maturity"
  }
}