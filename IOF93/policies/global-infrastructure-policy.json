{
  "id": "global-infrastructure-policy",
  "name": "Global Infrastructure Policy",
  "version": "1.0",
  "what": {
    "domains": {
      "match": [
        {
          "field": "domain",
          "op": "in",
          "value": [
            "infrastructure",
            "carrier",
            "platform"
          ]
        },
        {
          "field": "countries",
          "op": "equals",
          "value": "*"
        }
      ]
    },
    "exclude": {
      "paths": [
        "./domains/test/*"
      ]
    }
  },
  "how": [
    "./analysis-profiles/standard-analysis.json",
    "./measurement-profiles/passive-standard.json"
  ],
  "selection": {
    "matchLogic": "AND",
    "includeGlobal": true
  }
}